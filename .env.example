# Default AI scoring provider. FreeLLM API is OpenAI-compatible and avoids
# running inference on this machine.
LLM_PROVIDER=freellmapi
FREELLMAPI_UNIFIED_API_KEY=
FREELLMAPI_BASE_URL=http://localhost:3001/v1
FREELLMAPI_MODEL=auto

# Optional local fallback instead of FreeLLM API.
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=gemma4:latest

# Required only for the optional Wellfound source.
APIFY_TOKEN=

# Optional overrides.
WELLFOUND_APIFY_ACTOR=blackfalcondata/wellfound-scraper
WELLFOUND_MAX_CHARGE_USD=1.00
